generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  phone     String    @unique
  name      String
  password  String
  role      String    // admin / driver
  avatar    String?
  status    Int       @default(1) // 1正常 0禁用
  createdAt DateTime  @default(now())

  driver Driver?
}

model Driver {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id])
  idCard      String?
  plateNo     String?
  vehicleType String?
  status      Int     @default(1)

  batches Batch[]
}

model Shipper {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  contact   String?
  phone     String?
  address   String?
  createdAt DateTime  @default(now())

  waybills Waybill[]
}

model Warehouse {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  address   String?
  city      String?
  createdAt DateTime  @default(now())

  waybills Waybill[]
}

model Waybill {
  id               Int       @id @default(autoincrement())
  waybillNo        String    @unique
  warehouseId      Int
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  shipperId        Int
  shipper          Shipper   @relation(fields: [shipperId], references: [id])
  receiverName     String
  receiverPhone    String
  receiverAddress  String
  receiverLng      Float?
  receiverLat      Float?
  temperatureLayer String    @default("常温") // 常温/冷藏/冷冻
  weight           Float     @default(0)
  itemType         String    @default("")
  packageCount     Int       @default(1)
  deadline         DateTime?
  signRequirement  String?
  codAmount        Float?
  remark           String?
  status           Int       @default(0)   // 0待分派 1待配送 2配送中 3已签收 4异常
  sortOrder        Int       @default(0)
  batchId          Int?
  batch            Batch?    @relation(fields: [batchId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  signRecords      SignRecord[]
  exceptionRecords ExceptionRecord[]
}

model Batch {
  id           Int       @id @default(autoincrement())
  batchNo      String    @unique
  driverId     Int
  driver       Driver    @relation(fields: [driverId], references: [id])
  deliveryDate String    // YYYY-MM-DD
  status       Int       @default(0) // 0待配送 1配送中 2已完成
  totalCount   Int       @default(0)
  finishedCount Int      @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  waybills Waybill[]
}

model SignRecord {
  id        Int       @id @default(autoincrement())
  waybillId Int
  waybill   Waybill   @relation(fields: [waybillId], references: [id])
  type      String    // signature / photo / proxy
  proxyName String?   // 代收人姓名（代收签收时）
  proxyRelation String? // 代收关系
  signature String?   // 签名图片base64或路径
  photos    String?   // 拍照图片路径（JSON数组）
  createdAt DateTime  @default(now())
}

model ExceptionRecord {
  id          Int       @id @default(autoincrement())
  waybillId   Int
  waybill     Waybill   @relation(fields: [waybillId], references: [id])
  type        String    // 拒收/无人接听/地址错误/货物破损/其他
  description String
  photos      String?   // 拍照图片路径（JSON数组）
  createdAt   DateTime  @default(now())
}
