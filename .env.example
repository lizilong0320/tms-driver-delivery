# Optional: GitHub Gist for persistent storage (free, public)
# 1. Create a public Gist with a file named "tms-db.json"
# 2. Add env vars in Vercel project settings
TMS_GIST_ID=your_gist_id_here
TMS_GIST_TOKEN=ghp_your_github_personal_access_token

# Optional: Vercel KV (Upstash Redis)
# Create via Vercel dashboard and copy the env vars
KV_REST_API_URL=
KV_REST_API_TOKEN=
